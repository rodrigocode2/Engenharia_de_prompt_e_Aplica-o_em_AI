# Como você não quer a biblioteca de leitura, inserimos as informações/links aqui
referencias_python = """
Links úteis para consulta:
1. Documentação Oficial: https://docs.python.org/3/
2. Guia para Iniciantes: https://wiki.python.org/moin/BeginnersGuide
3. Repositório de Pacotes (PyPI): https://pypi.org/
Dica técnica: Sempre priorize o uso de ambientes virtuais (venv) e siga o PEP 8.
"""

# ==========================================
# CONFIGURAÇÃO DO CHAT
# ==========================================
chat = ChatGroq(model='llama-3.3-70b-versatile', temperature=0.5)

def obter_resposta(historico):
    # O bot recebe os links e informações direto no sistema
    comando_sistema = [
        ('system', f'Você é a Minha_IA. Use estas referências se necessário: {referencias_python}')
    ]
    
    template = ChatPromptTemplate.from_messages(comando_sistema + historico)
    chain = template | chat
    return chain.invoke({}).content

# ==========================================
# LOOP DE CONVERSA
# ==========================================
print('--- Minha_IA Ativa ---')
mensagens = []

while True:
    pergunta = input('Usuário: ')
    if pergunta.lower() == 'x': break
    
    mensagens.append(('user', pergunta))
    try:
        res = obter_resposta(mensagens)
        mensagens.append(('assistant', res))
        print(f'Bot: {res}\n')
    except Exception as e:
        print(f'Erro: {e}')
        break
